{
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 80,
  "bracketSpacing": true,
  "proseWrap": "always",
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "^@/app/(.*)$",
    "^@/features/(.*)$",
    "^@/shared/components/(.*)$",
    "^@/shared/components/ui/(.*)$",
    "^@/shared/config/(.*)$",
    "^@/constants/(.*)$",
    "^@/shared/graphql/(.*)$",
    "^@/shared/hooks/(.*)$",
    "^@/shared/types/(.*)$",
    "^@/shared/lib/(.*)$",
    "^@/shared/utils/(.*)$",
    "^@/shared/api/(.*)$",
    "^@/__generated__/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "plugins": [
    "prettier-plugin-tailwindcss",
    "@trivago/prettier-plugin-sort-imports"
  ]
}
